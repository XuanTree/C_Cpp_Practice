{
    "version": 8,
    "configurePresets": [
        {
            "name": "clang19",
            "displayName": "Clang 19.1.7 x86_64-w64-windows-gnu",
            "description": "正在使用编译器: C = D:\\MinGW64\\bin\\clang.exe, CXX = D:\\MinGW64\\bin\\clang++.exe",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "D:/MinGW64/bin/clang.exe",
                "CMAKE_CXX_COMPILER": "D:/MinGW64/bin/clang++.exe",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}